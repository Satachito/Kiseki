const
Add = ( p, q ) => p.map( ( $, _ ) => $ + q[ _ ] )

const
Sub = ( p, q ) => p.map( ( $, _ ) => $ - q[ _ ] )

const
Vec = ( p, q ) => p.map( ( $, _ ) => q[ _ ] - $ )

const
Mul = ( $, _ ) => $.map( $ => $ * _ )

const
Div = ( $, _ ) => $.map( $ => $ / _ )

const
Mid = ( p, q ) => p.map( ( $, _ ) => ( $ + q[ _ ] ) / 2 )

const
EQ = ( p, q ) => p.every( ( $, _ ) => $ === q[ _ ] )

const
Near = ( p, q ) => p.every( ( $, _ ) => Math.abs( $ - q[ _ ] ) <= 1 )

const
Round = $ => $.map( $ => Math.round( $ ) )

const
LineGrids = ( s, e ) => {
	const rS	= Round( s )
	const rE	= Round( e )
	if ( Near( rS, rE ) ) return []

	const $		= Mid( s, e )
	const rM	= Round( $ )

	return [
		...LineGrids( s, $ )
	,	rM
	,	...LineGrids( $, e )
	]
}

const
QuadGrids = ( s, c, e ) => {
	const rS	= Round( s )
	const rE	= Round( e )

	const sc	= Mid( s, c )
	const ce	= Mid( c, e )
	const $		= Mid( sc, ce )
	const rM	= Round( $ )

	return Near( rS, rM ) && Near( rM, rE )
	?	Near( rS, rE ) ? [] : [ rM ]
	:	[	...QuadGrids( s, sc, $ )
		,	rM
		,	...QuadGrids( $, ce, e )
		]
}

const
CubeGrids = ( s, p, q, e ) => {
	const rS	= Round( s )
	const rE	= Round( e )

	const sp	= Mid( s, p )
	const qe	= Mid( q, e )
	const pq	= Mid( p, q )
	const spq	= Mid( sp, pq )
	const pqe	= Mid( pq, qe )
	const $		= Mid( spq, pqe )

	const rM	= Round( $ )

	return Near( rS, rM ) && Near( rM, rE )
	?	Near( rS, rE ) ? [] : [ rM ]
	:	[	...CubeGrids( s, sp, spq, $ )
		,	rM
		,	...CubeGrids( $, pqe, qe, e )
		]
}

////////

const
c2D = CANVAS.getContext( '2d' )

const
d2D = DEBUG.getContext( '2d' )

let
glyph = []

const
Begin = () => glyph.length = 0

const
MoveTo = _ => {
	const $ = []
	$.moveTo = _
	glyph.unshift( $ )
	return $
}

const
LineTo = _ => {
	const $ = glyph.length
	?	glyph[ 0 ]
	:	MoveTo( [ 0, 0 ] )
	$.unshift( [ _ ] )
	return $
}

const
QuadTo = ( c, _ ) => {
	const $ = glyph.length
	?	glyph[ 0 ]
	:	MoveTo( [ 0, 0 ] )
	$.unshift( [ _, c ] )
	return $
}

const
CubeTo = ( p, q, _ ) => {
	const $ = glyph.length
	?	glyph[ 0 ]
	:	MoveTo( [ 0, 0 ] )
	$.unshift( [ _, q, p ] )
	return $
}

const
ClosePath = () => {
	if ( !glyph.length ) return
	const _ = glyph[ 0 ]
	if ( !_.moveTo ) return
	if ( !EQ( _.moveTo, glyph[ 0 ][ 0 ] ) ) _.unshift( [ _.moveTo ] )
	delete _.moveTo
}

const	//	!!DESTRUCTIVE!!
Opt = ( s, $, e ) => {
	let next = Sub( $.at( -1 ), e )
	let _ = $.length
	while ( _-- ) {
if ( next[ 0 ] === 0 && next[ 1 ] === 0 ) debugger
		const prev = Sub( _ ? $[ _ - 1 ] : s, $[ _ ] )
if ( prev[ 0 ] === 0 && prev[ 1 ] === 0 ) debugger
		if ( ( prev[ 0 ] === 0 && next[ 1 ] === 0 ) || ( prev[ 1 ] === 0 && next[ 0 ] === 0 ) ) $.splice( _, 1 )
		next = prev
	}
	return $
}

const
Grids = ( cp, S ) => {
	switch ( S.length ) {
	case 1	: return LineGrids( cp, S[ 0 ] )
	case 2	: return Opt( cp, QuadGrids( cp, S[ 1 ], S[ 0 ] ), S[ 0 ] )
	case 3	: return Opt( cp, CubeGrids( cp, S[ 2 ], S[ 1 ], S[ 0 ] ), S[ 0 ] )
	default	: debugger
	}
}

const
ContourGrids = C => {
	const
	$ = []
	let	cp = C[ 0 ][ 0 ]
	C.moveTo && $.push( Round( cp = C.moveTo ) )
	let iC = C.length
	while ( iC-- ) {
		const S = C[ iC ]
		const grids = Grids( cp, S )
		const _ = Round( S[ 0 ] )
		grids.length
		?	$.push( ...grids, _ )
		:	EQ( Round( cp ), _ ) || $.push( _ )
		cp = S[ 0 ]
	}
	return $
}

const
Skelton = () => {
	const
	FR = ( [ x, y ], r ) => c2D.fillRect( x * 4 - r, y * 4 - r, r * 2, r * 2 )
	c2D.fillStyle = 'black'
	glyph.forEach( C => ContourGrids( C ).forEach( _ => FR( _, 2 ) ) )
	c2D.fillStyle = 'white'
	glyph.forEach(
		C => (
			C.moveTo && FR( C.moveTo, 1 )
		,	C.map( S => Round( S[ 0 ] ) ).forEach( _ => FR( _, 1 ) )
		)
	)
}

const
ClosedContourGrids = C => {
	const $ = ContourGrids( C )
	C.moveTo && $.push( ...LineGrids( C[ 0 ][ 0 ], C.moveTo ) )
	return $
}

const
FillArea = () => {
	const
	moveTo = ( [ x, y ] ) => c2D.moveTo( x * 8, y * 8 )
	const
	lineTo = ( [ x, y ] ) => c2D.lineTo( x * 8, y * 8 )
	c2D.lineWidth = 8
	glyph.forEach(
		C => {
			const $ = ClosedContourGrids( C )
			moveTo( $[ 0 ] )
			for ( let _ = 1; _ < $.length; _++ ) lineTo( $[ _ ] )
			c2D.closePath()
		}
	)
	c2D.stroke()
}

const
BBox = _ => _.reduce(
	( $, _ ) => [
		_[ 0 ] < $[ 0 ] ? _[ 0 ] : $[ 0 ]
	,	_[ 1 ] < $[ 1 ] ? _[ 1 ] : $[ 1 ]
	,	_[ 0 ] > $[ 2 ] ? _[ 0 ] : $[ 2 ]
	,	_[ 1 ] > $[ 3 ] ? _[ 1 ] : $[ 3 ]
	]
,	[ ..._[ 0 ], ..._[ 0 ] ]
)

/*	reserved ABBREVIATION
	X, Y, Z, x, y, z
	W, H, D
	G: Glyph
	C: Contour
	S: Section
	P: Point
*/
const
BitRGBAs = G => {
	const bbox = BBox( G.flat().flat() )
	const X = Math.floor( bbox[ 0 ] )
	const Y = Math.floor( bbox[ 1 ] )
	const W = Math.ceil( bbox[ 2 ] ) - X + 2
	const H = Math.ceil( bbox[ 3 ] ) - Y + 2
	const $ = new Int8Array( W * H )
	$.fill( 0 )
	
	const
	contourGridsList = G.map( C => ClosedContourGrids( C ).map( ( [ x, y ] ) => [ x - X + 1, y - Y + 1 ] ) )

	contourGridsList.forEach(
		_ => {
			let [ pX, pY ] = _.at( -1 )
			_.forEach(
				( [ cX, cY ] ) => (
					pY !== cY && (
						pY < cY
						?	$[ pY * W + ( pX < cX ? pX : cX ) ]++
						:	$[ cY * W + ( pX < cX ? cX : pX ) ]--
					)
				,	[ pX, pY ] = [ cX, cY ]
				)
			)
		}
	)

	//					xxxxrgba	
	//	transparent	:	bbbbbbb0
	//	black		:	bbbb0001
	//	red			:	bbbb1001
	//	white		:	bbbb1111
	switch ( 'nonzero' ) {
	case 'nonzero':
		for ( let y = 0; y < H; y++ ) {
			let i = y * W + 1
			let _ = $[ i ]
			$[ i ] = _ ? 0xff : 0
			while ( ++i < y * W + W ) (
				_ += $[ i ]
			,	$[ i ] = _ ? 0xff : 0
			)
		}
		break
	case 'evenodd':
		break
	}

	return [ $, X - 1, Y - 1, W, H ]
}

const
Fill = () => {
	const
	[ bitRGBAs, X, Y, W, H ] = BitRGBAs( glyph )
	const
	$ = c2D.createImageData( W, H )
	const
	data = $.data
	const
	nPerV = W * 4
	const
	Plot = ( x, y, r, g, b, a ) => {
		let _ = y * nPerV + x * 4
		data[ _++ ] = r
		data[ _++ ] = g
		data[ _++ ] = b
		data[ _++ ] = a
	}

	for ( let y = 0; y < H; y++ ) {
		for ( let x = 0; x < W; x++ ) bitRGBAs[ y * W + x ] == -1 && Plot( x, y, 0, 0, 0, 0xff )
	}
	c2D.putImageData( $, X, Y )
}

const
DebugFill = N => {

	const
	[ bitRGBAs, X, Y, W, H ] = BitRGBAs( glyph )
	const
	$ = d2D.createImageData( W * N, H * N )
	const
	data = $.data
	const
	nPerH = N * 4
	const
	nPerLine = W * nPerH
	const
	nPerV = nPerLine * N
	const
	Plot = ( x, y, r, g, b, a ) => {
		x *= nPerH
		y *= nPerV
		for ( let _y = 0; _y < N; _y++ ) {
			let _ = y + x
			for ( let _x = 0; _x < N; _x++ ) (
				data[ _++ ] = r
			,	data[ _++ ] = g
			,	data[ _++ ] = b
			,	data[ _++ ] = a
			)
			y += nPerLine
		}
	}

	for ( let y = 0; y < H; y++ ) {
		for ( let x = 0; x < W; x++ ) bitRGBAs[ y * W + x ] == -1 && Plot( x, y, 0, 0, 0, 0x40 )
	}
	DEBUG.width = $.width
	DEBUG.height = $.height
	d2D.putImageData( $, 0, 0 )
}

const
Draw = () => (
	MoveTo( [ 1, 1 ] )
,	LineTo( [ 5, 1 ] )
,	LineTo( [ 5, 5 ] )
,	LineTo( [ 1, 5 ] )
,	ClosePath()
,	Fill()
,	DebugFill( 4 )
/*
	MoveTo( [ 50, 50 ] )
,	LineTo( [ 150, 50 ] )
,	QuadTo( [ 200, 100 ], [ 150, 150 ] )
,	CubeTo( [ 50, 150 ], [ 50, 150 ], [ 50, 100 ] )
,	ClosePath()
,	Skelton()
,	FillArea()
*/
)

onload = async () => (
	glyph = ( await fetch( '_.ved' ).then( _ => _.json() ) )[ 0 ][ 0 ][ 3 ].map( _ => _[ 1 ] )
,	Fill()
,	DebugFill( 4 )
)
